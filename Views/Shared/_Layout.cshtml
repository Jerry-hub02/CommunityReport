<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Community Portal</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@3.3.7/dist/css/bootstrap.min.css" integrity="sha384-BVYiiSIFeK1dGmJRAkycuHAHRg32OmUcww7on3RYdg4Va+PmSTsz/K68vbdEjh4u" crossorigin="anonymous">
    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .navbar-custom {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #4facfe 100%);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
            padding: 1rem 0;
            position: relative;
            overflow: visible;
            overflow-x: hidden;
            /* overflow-y: visible; */
            z-index: 1000;
        }

            .navbar-custom::before {
                content: '';
                position: absolute;
                top: 0;
                left: -100%;
                width: 100%;
                height: 100%;
                background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
                animation: shimmer 3s infinite;
            }

        @@keyframes shimmer {
            0% {
                left: -100%;
            }

            100% {
                left: 100%;
            }
        }

        .navbar-brand {
            color: white !important;
            font-weight: 700;
            font-size: 1.5rem;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.2);
            transition: transform 0.3s ease;
        }

            .navbar-brand:hover {
                transform: scale(1.05);
            }

        .nav-link {
            color: rgba(255, 255, 255, 0.9) !important;
            font-weight: 500;
            padding: 0.5rem 1rem !important;
            margin: 0 0.2rem;
            border-radius: 8px;
            transition: all 0.3s ease;
            position: relative;
            display: flex;
            align-items: center;
        }

            .nav-link:hover {
                background: rgba(255, 255, 255, 0.2);
                transform: translateY(-2px);
                color: white !important;
            }

            .nav-link i {
                margin-right: 0.5rem;
            }

        .dropdown-menu {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.2);
            border-radius: 12px;
            padding: 0.5rem;
            animation: dropdownSlide 0.3s ease;
        }

        @@keyframes dropdownSlide {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .dropdown-item {
            color: white !important;
            padding: 0.7rem 1rem;
            border-radius: 8px;
            transition: all 0.3s ease;
        }

            .dropdown-item:hover {
                background: rgba(255, 255, 255, 0.2);
                transform: translateX(5px);
            }

        .dropdown-divider {
            border-color: rgba(255, 255, 255, 0.2);
        }

        @@keyframes pulse {
            0%, 100% {
                transform: scale(1);
            }

            50% {
                transform: scale(1.1);
            }
        }

        .btn-logout {
            background: rgba(255, 255, 255, 0.2);
            color: white !important;
            border: 2px solid rgba(255, 255, 255, 0.3);
            padding: 0.5rem 1.5rem;
            border-radius: 25px;
            font-weight: 600;
            transition: all 0.3s ease;
        }

            .btn-logout:hover {
                background: rgba(255, 255, 255, 0.3);
                border-color: white;
                transform: scale(1.05);
                box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
            }

        .navbar-toggler {
            border-color: rgba(255, 255, 255, 0.5);
            display: none;
        }

        .navbar-toggler-icon {
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='rgba(255, 255, 255, 1)' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e");
        }

        .navbar-nav {
            list-style: none;
            margin: 0;
            padding: 0;
            align-items: center;
        }

        .navbar-item {
            display: flex;
            align-items: center;
        }

        .navbar-collapse {
            align-items: center;
        }

        .navbar-nav li {
            list-style: none;
            list-style-type: none;
        }

        .content-area {
            padding: 2rem;
            min-height: 80vh;
            background: linear-gradient(to bottom, #f8f9fa, #e9ecef);
        }

        /* Notification bell animation */
    @@keyframes shake {
        0%, 100% { transform: rotate(0deg); }
        10%, 30%, 50%, 70%, 90% { transform: rotate(-10deg); }
        20%, 40%, 60%, 80% { transform: rotate(10deg); }
    }
    
    .shake {
        animation: shake 0.5s;
    }
    
    /* Notification badge styling */
    #notificationBadge {
        padding: 0.25rem 0.5rem;
        min-width: 1.2rem;
        height: 1.2rem;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    /* Bell hover effect */
    #notificationBell:hover i {
        transform: scale(1.1);
        transition: transform 0.2s;
    }

    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-custom">
        <div class="container-fluid">
            <a class="navbar-brand" href="/Dashboard/Display">
                <i class="bi bi-house-heart"></i> Community Portal
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/Dashboard/Display">
                            <i class="bi bi-speedometer2"></i> Dashboard
                        </a>
                    </li>
                    @if (User.IsInRole("admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Admin/Display">
                                <i class="bi bi-shield-lock"></i> Admin Page
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link notification-link" href="@Url.Action("BroadcastNotification", "Admin")">
                                <i class="bi bi-megaphone"></i> Broadcast
                            </a>
                        </li>
                    }
                    <li class="nav-item">
                        <a class="nav-link" href="/Complaints/Index">
                            <i class="bi bi-file-text"></i> Complaints
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Index", "ChatRooms")">
                            <i class="bi bi-chat-dots"></i> Chat Rooms
                        </a>
                    </li>
                            <li class="nav-item">
                                <a class="nav-link position-relative" href="@Url.Action("Index", "Notifications")" id="notificationBell">
                                    <i class="bi bi-bell-fill" style="font-size: 1.3rem;"></i>Notifications
                                    <span id="notificationBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="display:none; font-size: 0.7rem;">
                                        0
                                    </span>
                                </a>
                            </li>
                </ul>
                <ul class="navbar-nav navbar-right">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle"></i> @User.Identity.Name
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <a class="dropdown-item" href="@Url.Action("Index", "Profile")">
                                    <i class="bi bi-person"></i> My Profile
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="@Url.Action("Index", "Complaints")">
                                    <i class="bi bi-file-text"></i> My Complaints
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="@Url.Action("Index", "ChatRooms")">
                                    <i class="bi bi-chat-dots"></i> Chat Rooms
                                </a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <form method="post" action="@Url.Action("Logout", "UserAuthentication")" style="display: inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-logout w-100">
                                        <i class="bi bi-box-arrow-right"></i> Logout
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
    <div class="content-area">
        <div class="container">
            @RenderBody()
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @if (User.Identity.IsAuthenticated && !User.IsInRole("admin"))
    {
        <script>
            // Update notification count
            function updateNotificationCount() {
                fetch('@Url.Action("GetUnreadCount", "Notifications")')
                    .then(response => response.json())
                    .then(data => {
                        var badge = document.getElementById('notificationBadge');
                        var bell = document.getElementById('notificationBell');

                        if (data.count > 0) {
                            badge.textContent = data.count;
                            badge.style.display = 'inline-block';

                            // Add animation to bell
                            bell.classList.add('shake');
                            setTimeout(() => bell.classList.remove('shake'), 500);
                        } else {
                            badge.style.display = 'none';
                        }
                    })
                    .catch(error => console.error('Error fetching notification count:', error));
            }

            // Update immediately on page load
            updateNotificationCount();

            // Update every 10 seconds
            setInterval(updateNotificationCount, 10000);
        </script>
    }
</body>
</html>
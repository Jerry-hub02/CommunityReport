@model Complaint

<button onclick="history.back()" class="btn btn-secondary mb-3">
    <i class="bi bi-arrow-left"></i> Back
</button>
<div class="container mt-4">
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h3>Complaint Details</h3>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="text-muted">ID</label>
                        <p class="fs-5"><strong>#@Model.Id</strong></p>
                    </div>

                    <div class="mb-3">
                        <label class="text-muted">Address</label>
                        <p class="fs-5"><strong>@Model.Title</strong></p>
                    </div>

                    <div class="mb-3">
                        <label class="text-muted">Type</label>
                        <p><span class="badge bg-info">@Model.Type</span></p>
                    </div>

                    <div class="mb-3">
                        <label class="text-muted">Status</label>
                        <p>
                            <span class="badge
                                @(Model.Status == "Submitted" ? "bg-secondary" :
                                  Model.Status == "Pending" ? "bg-warning" :
                                  Model.Status == "Resolved" ? "bg-success" :
                                  Model.Status == "InProgress" ? "bg-info" : "bg-secondary")">
                                @Model.Status
                            </span>
                        </p>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="text-muted">Created At</label>
                        <p class="fs-5"><strong>@Model.CreatedAt.ToString("MMM dd, yyyy hh:mm tt")</strong></p>
                    </div>
                </div>
            </div>

            <hr />

            <div class="mb-3">
                <label class="text-muted">Description</label>
                <p class="fs-5">@Model.Description</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ImagePath))
            {
                <div class="mb-3">
                    <label class="text-muted">Attached Image</label>
                    <div>
                        <img src="~/Complaint/@Model.ImagePath" alt="Complaint Image" class="img-fluid" style="max-height: 500px; border-radius: 8px;" />
                    </div>
                </div>
            }

            <hr />

            <div class="d-flex gap-2">
                <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-warning">
                    <i class="bi bi-pencil"></i> Edit
                </a>
                <a href="@Url.Action("Index")" class="btn btn-secondary">
                    <i class="bi bi-list"></i> Back to List
                </a>
                <form method="post" action="@Url.Action("Delete", new { id = Model.Id })" style="display:inline;"
                      onsubmit="return confirm('Are you sure you want to delete this complaint?');">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
@{

}

<button onclick="history.back()" class="btn btn-secondary mb-3">
    <i class="bi bi-arrow-left"></i> Back
</button>

<h2>Admin Dashboard</h2>

<div class="row mt-4">
    <div class="col-md-3">
        <div class="card text-white bg-primary">
            <div class="card-body">
                <h5 class="card-title">Total Complaints</h5>
                <h2>@ViewData["TotalComplaints"]</h2>
            </div>
        </div>
    </div>
    
    <div class="col-md-3">
        <div class="card text-white bg-warning">
            <div class="card-body">
                <h5 class="card-title">Pending</h5>
                <h2>@ViewData["PendingComplaints"]</h2>
            </div>
        </div>
    </div>
    
    <div class="col-md-3">
        <div class="card text-white bg-success">
            <div class="card-body">
                <h5 class="card-title">Resolved</h5>
                <h2>@ViewData["ResolvedComplaints"]</h2>
            </div>
        </div>
    </div>
    
    <div class="col-md-3">
        <div class="card text-white bg-info">
            <div class="card-body">
                <h5 class="card-title">Total Users</h5>
                <h2>@ViewData["TotalUsers"]</h2>
            </div>
        </div>
    </div>
</div>
<div class="mt-4">
    <a href="@Url.Action("Complaints")" class="btn btn-primary">View All Complaints</a>
    <a href="@Url.Action("BroadcastNotification")" class="btn btn-danger">Send Notification to All Users</a>
</div>
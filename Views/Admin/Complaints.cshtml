@model IEnumerable<Complaint>

<button onclick="history.back()" class="btn btn-secondary mb-3">
    <i class="bi bi-arrow-left"></i> Back
</button>
<h2>All User Complaints</h2>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success">
        @TempData["Message"]
    </div>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Address</th>
            <th>Type</th>
            <th>Description</th>
            <th>Status</th>
            <th>Created At</th>
            <th>User ID</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var complaint in Model)
        {
            <tr>
                <td>@complaint.Id</td>
                <td>@complaint.Title</td>
                <td>@complaint.Type</td>
                <td>@(complaint.Description.Length > 50 ? complaint.Description.Substring(0, 50) + "..." : complaint.Description)</td>
                <td>
                    <span class="badge
                        @(complaint.Status == "Submitted" ? "bg-secondary" :
                          complaint.Status == "Pending" ? "bg-warning" :
                          complaint.Status == "Resolved" ? "bg-success" :
                          complaint.Status == "InProgress" ? "bg-info" : "bg-secondary")">
                        @complaint.Status
                    </span>
                </td>
                <td>@complaint.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                <td>@complaint.UserId.Substring(0, 8)...</td>
                <td>
                    <a href="@Url.Action("ComplaintDetails", new { id = complaint.Id })" class="btn btn-sm btn-info">View</a>
                    <a href="@Url.Action("ChangeStatus", new { id = complaint.Id })" class="btn btn-sm btn-warning">Change Status</a>
                    <form method="post" action="@Url.Action("DeleteComplaint", new { id = complaint.Id })" style="display:inline;"
                          onsubmit="return confirm('Are you sure you want to delete this complaint?');">
                        <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
<button onclick="history.back()" class="btn btn-secondary mb-3">
    <i class="bi bi-arrow-left"></i> Back
</button>
<h2>Send Notification</h2>
<div class="alert alert-info">
    Sending notification about complaint: <strong>@ViewData["ComplaintTitle"]</strong>
</div>

<form method="post">
    <input type="hidden" name="complaintId" value="@ViewData["ComplaintId"]" />

    <div class="form-group">
        <label>Title</label>
        <input type="text" name="title" class="form-control" required placeholder="e.g., Your complaint has been resolved" />
    </div>

    <div class="form-group mt-3">
        <label>Message</label>
        <textarea name="message" class="form-control" rows="5" required placeholder="Enter notification details..."></textarea>
    </div>

    <button type="submit" class="btn btn-primary mt-3">Send Notification</button>
    <a href="@Url.Action("ComplaintDetails", new { id = ViewData["ComplaintId"] })" class="btn btn-secondary mt-3">Cancel</a>
</form>
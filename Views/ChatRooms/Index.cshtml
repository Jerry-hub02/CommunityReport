@using System.Security.Claims
@model IEnumerable<ChatRoom>

<button onclick="history.back()" class="btn btn-secondary mb-3">
    <i class="bi bi-arrow-left"></i> Back
</button>
<h2>My Chat Rooms</h2>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="mb-3">
    <a href="@Url.Action("Create")" class="btn btn-primary">Create New Chat Room</a>
    <a href="@Url.Action("Browse")" class="btn btn-info">Browse All Rooms</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        You haven't joined any chat rooms yet. Click "Browse All Rooms" to find rooms to join!
    </div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Created By</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var room in Model)
            {
                var isCreator = room.CreatedById == User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier);

                <tr>
                    <td>@room.Name</td>
                    <td>@room.Description</td>
                    <td>
                        @if (isCreator)
                        {
                            <span class="badge bg-success">You</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Other</span>
                        }
                    </td>
                    <td>
                        <a href="@Url.Action("Chat", new { id = room.Id })" class="btn btn-sm btn-primary">Open Chat</a>

                        @if (isCreator)
                        {
                            <form method="post" action="@Url.Action("DeleteRoom", new { id = room.Id })" style="display:inline;"
                                  onsubmit="return confirm('Are you sure you want to delete this chat room? All messages will be lost!');">
                                <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                            </form>
                        }
                        else
                        {
                            <form method="post" action="@Url.Action("LeaveRoom", new { id = room.Id })" style="display:inline;"
                                  onsubmit="return confirm('Are you sure you want to leave this chat room?');">
                                <button type="submit" class="btn btn-sm btn-warning">Leave</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}